# Social Studio server environment template.
# Copy this file to /opt/social-studio/.env on the server only.
# The real /opt/social-studio/.env is chmod 600 and is never committed.

# Optional. Leave blank to use template generation instead of AI generation.
ANTHROPIC_API_KEY=

# Optional reviewer name allowlist for manual decisions.
STUDIO_REVIEWERS=Jen,Andre

# Keep the app bound to localhost. Caddy is the public listener.
HOST=127.0.0.1
PORT=4810
