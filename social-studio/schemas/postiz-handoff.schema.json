{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crystalclawz.local/social-studio/schemas/postiz-handoff.schema.json",
  "title": "Crystal Clawz Postiz Handoff Package",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "enum": ["draft_upload_ready", "handed_to_postiz"]
          }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "review": {
            "properties": {
              "approvedBy": {
                "type": "string",
                "minLength": 2,
                "not": { "const": "pending-human-review" }
              },
              "approvedAt": { "type": "string", "minLength": 10 },
              "notLiveConfirmed": { "const": true }
            },
            "required": ["approvedBy", "approvedAt", "notLiveConfirmed"]
          }
        }
      }
    }
  ],
  "required": [
    "campaignId",
    "assetId",
    "handoffMode",
    "platforms",
    "media",
    "caption",
    "hashtags",
    "status",
    "review"
  ],
  "properties": {
    "campaignId": { "type": "string", "minLength": 3 },
    "assetId": { "type": "string", "minLength": 3 },
    "handoffMode": {
      "type": "string",
      "enum": ["manual_upload", "postiz_api_draft"]
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["instagram", "facebook", "tiktok", "youtube_shorts", "pinterest", "threads"]
      }
    },
    "media": {
      "type": "object",
      "additionalProperties": false,
      "required": ["localPath", "mediaType"],
      "properties": {
        "localPath": { "type": "string", "minLength": 3 },
        "thumbnailPath": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["video", "image", "carousel"] },
        "durationSeconds": { "type": "number" },
        "aspectRatio": { "type": "string" }
      }
    },
    "reviewAssets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["assetId", "contentType", "mediaType"],
        "properties": {
          "assetId": { "type": "string", "minLength": 3 },
          "label": { "type": "string" },
          "contentType": { "type": "string", "minLength": 3 },
          "mediaType": { "type": "string", "enum": ["video", "image", "carousel"] },
          "localPath": { "type": "string" },
          "assetUrl": { "type": "string" },
          "supportingAssets": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "assetUrl"],
              "properties": {
                "type": { "type": "string", "minLength": 3 },
                "assetUrl": { "type": "string" },
                "localPath": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "caption": { "type": "string", "minLength": 3 },
    "hashtags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scheduledFor": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["needs_review", "draft_upload_ready", "handed_to_postiz"]
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approvedBy", "approvedAt", "notLiveConfirmed"],
      "properties": {
        "approvedBy": { "type": "string" },
        "approvedAt": { "type": "string" },
        "notLiveConfirmed": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    }
  }
}
