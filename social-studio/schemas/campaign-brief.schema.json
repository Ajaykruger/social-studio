{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crystalclawz.local/social-studio/schemas/campaign-brief.schema.json",
  "title": "Crystal Clawz Campaign Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "campaignId",
    "campaignName",
    "product",
    "audience",
    "painPoint",
    "contentType",
    "platforms",
    "cta",
    "tone",
    "claimSource",
    "reviewer",
    "status"
  ],
  "properties": {
    "campaignId": { "type": "string", "minLength": 3 },
    "campaignName": { "type": "string", "minLength": 3 },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "category", "url"],
      "properties": {
        "name": { "type": "string", "minLength": 2 },
        "category": { "type": "string", "minLength": 2 },
        "url": { "type": "string", "minLength": 5 }
      }
    },
    "audience": { "type": "string", "minLength": 3 },
    "painPoint": { "type": "string", "minLength": 3 },
    "contentType": {
      "type": "string",
      "enum": ["ugc_video", "paid_ad_video", "normal_post", "product_demo", "educational_post"]
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["instagram", "facebook", "tiktok", "youtube_shorts", "pinterest", "threads"]
      }
    },
    "cta": { "type": "string", "minLength": 3 },
    "tone": { "type": "string", "minLength": 3 },
    "claimSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceType", "sourceRef", "approvedBenefits", "blockedClaims"],
      "properties": {
        "sourceType": { "type": "string", "enum": ["product_page", "internal_brand_file", "manual_approval"] },
        "sourceRef": { "type": "string", "minLength": 3 },
        "approvedBenefits": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blockedClaims": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "reviewer": { "type": "string", "minLength": 2 },
    "dueDate": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["brief", "draft_generated", "needs_review", "approved", "draft_upload_ready", "handed_to_postiz", "needs_revision", "rejected"]
    }
  }
}
