{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crystalclawz.local/social-studio/schemas/product-input.schema.json",
  "title": "Crystal Clawz Product Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "productId",
    "name",
    "category",
    "sourceUrl",
    "approvedBenefits",
    "blockedClaims",
    "requiredVisuals",
    "approvalNote"
  ],
  "properties": {
    "productId": { "type": "string", "minLength": 3 },
    "name": { "type": "string", "minLength": 2 },
    "category": { "type": "string", "minLength": 2 },
    "sourceUrl": { "type": "string", "minLength": 5 },
    "approvedBenefits": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "blockedClaims": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 }
    },
    "requiredVisuals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "product_closeup",
          "shade_or_swatch",
          "application_context",
          "finished_result",
          "cta_end_frame"
        ]
      }
    },
    "mediaFolder": { "type": "string" },
    "approvalNote": { "type": "string", "minLength": 3 },
    "lastReviewedAt": { "type": "string" },
    "reviewedBy": { "type": "string" }
  }
}
